{
  "layers": {
    "input": {
      "display_name": "Input",
      "category": "core",
      "is_source_only": true,
      "keras_mapping": "tf.keras.layers.InputLayer",
      "params": {
        "dim_1": { "type": "number", "default": 28, "min": 1, "required": true },
        "dim_2": { "type": "number", "default": 28, "min": 1, "required": false },
        "dim_3": { "type": "number", "default": 1, "min": 1, "required": false }
      }
    },
    "dense": {
      "display_name": "Dense",
      "category": "core",
      "keras_mapping": "tf.keras.layers.Dense",
      "params": {
        "units": { "type": "number", "default": 32, "min": 1, "required": true },
        "activation": { "type": "select", "options": ["relu", "sigmoid", "softmax", "linear", "tanh"], "default": "relu", "required": false }
      }
    },
    "flatten": {
      "display_name": "Flatten",
      "category": "core",
      "keras_mapping": "tf.keras.layers.Flatten",
      "params": {}
    },
    "conv2d": {
      "display_name": "Conv2D",
      "category": "convolutional",
      "keras_mapping": "tf.keras.layers.Conv2D",
      "params": {
        "filters": { "type": "number", "default": 32, "min": 1, "required": true },
        "kernel_size_rows": { "type": "number", "default": 3, "min": 1, "required": true },
        "kernel_size_cols": { "type": "number", "default": 3, "min": 1, "required": true },
        "stride_rows": { "type": "number", "default": 1, "min": 1, "required": false },
        "stride_cols": { "type": "number", "default": 1, "min": 1, "required": false },
        "padding": { "type": "select", "options": ["valid", "same"], "default": "valid", "required": false },
        "activation": { "type": "select", "options": ["relu", "sigmoid", "softmax", "linear"], "default": "relu", "required": false }
      }
    }
  }
}